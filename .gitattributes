# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Go files
*.go text eol=lf

# JavaScript/React files
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf

# CSS files
*.css text eol=lf

# Markdown
*.md text eol=lf

# Shell scripts
*.sh text eol=lf

# Config files
*.config.js text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files (no conversion)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary